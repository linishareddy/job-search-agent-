# Database
POSTGRES_USER=jobsearch
POSTGRES_PASSWORD=jobsearch
POSTGRES_DB=jobsearch
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Groq
GROQ_API_KEY=
# Job source API keys
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=

# Application
APP_ENV=development
LOG_LEVEL=INFO

# Scheduler
SCHEDULER_MIN_INTERVAL_MINUTES=30

# Relevance threshold for notifications (1-10 scale)
NOTIFICATION_SCORE_THRESHOLD=7.0

# Auth
JWT_SECRET=
JWT_EXPIRE_MINUTES=1440

# Email (Resend HTTP API — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=Job Agent <onboarding@resend.dev>
EMAIL_ENABLED=false

# Seed user — owns pre-existing data after the multi-user migration
SEED_USER_EMAIL=you@example.com

# Auto-apply
AUTO_APPLY_INTERVAL_MINUTES=15
