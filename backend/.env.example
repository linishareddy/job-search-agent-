# Database
POSTGRES_USER=jobsearch
POSTGRES_PASSWORD=jobsearch
POSTGRES_DB=jobsearch
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Groq
GROQ_API_KEY=
# Job source API keys
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=

# Application
APP_ENV=development
LOG_LEVEL=INFO

# Scheduler
SCHEDULER_MIN_INTERVAL_MINUTES=30

# Relevance threshold for notifications (1-10 scale)
NOTIFICATION_SCORE_THRESHOLD=7.0

# Auth
JWT_SECRET=
JWT_EXPIRE_MINUTES=1440

# Email (Resend HTTP API — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=Job Agent <onboarding@resend.dev>
EMAIL_ENABLED=false
FRONTEND_URL=http://localhost:3000

# Seed user — owns pre-existing data after the multi-user migration
SEED_USER_EMAIL=you@example.com

# Auto-apply
AUTO_APPLY_INTERVAL_MINUTES=15

# JobSpy — LinkedIn + Indeed (US-focused)
JOBSPY_DEFAULT_LOCATION=United States
JOBSPY_US_ONLY=true
JOBSPY_COUNTRY_INDEED=USA

# Dice MCP (official, no API key)
DICE_MCP_URL=https://mcp.dice.com/mcp
# Optional rotating proxies if boards start blocking requests
# JOBSPY_PROXIES=http://user:pass@proxy1:8080,http://proxy2:8080

# LinkedIn Easy Apply (local Playwright script only — not stored in DB)
# LINKEDIN_EMAIL=you@example.com
# LINKEDIN_PASSWORD=your-password
