# Database
POSTGRES_USER=jobsearch
POSTGRES_PASSWORD=jobsearch
POSTGRES_DB=jobsearch
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Groq
GROQ_API_KEY=
# Job source API keys
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
